# ============================================
# App
# ============================================
APP_NAME=AAT Internal Portal
APP_ENV=development
DEBUG=true
DOMAIN=portal.aat.local
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ============================================
# Security
# ============================================
SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# Database
# ============================================
POSTGRES_DB=aat_portal
POSTGRES_USER=aat_user
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://aat_user:change_me@postgres:5432/aat_portal

# ============================================
# Redis / Celery
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ============================================
# Email
# ============================================
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=example@example.com
SMTP_PASSWORD=change_me
SMTP_FROM=example@example.com
SMTP_USE_TLS=true

# ============================================
# Telegram
# ============================================
TELEGRAM_BOT_TOKEN=change_me
TELEGRAM_CHAT_ID=change_me

# ============================================
# Uploads
# ============================================
UPLOAD_DIR=/app/backend/uploads
MAX_UPLOAD_SIZE_MB=10

# ============================================
# Frontend
# ============================================
VITE_API_BASE_URL=https://portal.aat.local/api

# CORS
# ============================================
CORS_ORIGINS=https://portal.aat.local
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type